    "Link: https://leetcode.com/problems/maximum-product-difference-between-two-pairs/"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "4c1fa759-3335-43ab-8982-32d82a42f15a",
   "metadata": {},
   "outputs": [],
   "source": [
    "from typing import List\n",
    "class Solution:\n",
    "    def maxProductDifference(self, nums: List[int]) -> int:\n",
    "        nums.sort()\n",
    "\n",
    "        return abs((nums[0]*nums[1]) - (nums[-1]*nums[-2]))"
   ]
  },
